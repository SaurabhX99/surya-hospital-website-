# Copy this file to .env and fill in your Twilio credentials.
# Leave blank to skip notifications — appointments still save to the database.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Twilio WhatsApp sandbox default — change once you have a dedicated WA number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

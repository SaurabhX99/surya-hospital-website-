# Copy this file to .env and fill in your values.
# Leave Twilio blank to skip notifications — appointments still save to the database.

# ── MongoDB ─────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
DATABASE_NAME=NIMMS_HOSPITAL

# ── Tenant ──────────────────────────────────────────────────────────
# Unique identifier for this hospital. Used to scope all DB queries.
# Change this per deployment — never share the same value across hospitals.
TENANT_NAME=vedansh_medicare

# ── Blog uploads ────────────────────────────────────────────────────
# Directory where uploaded article files are stored (relative to main.py)
UPLOAD_DIR=static/blogs

# ── Twilio ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Twilio WhatsApp sandbox default — change once you have a dedicated WA number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
